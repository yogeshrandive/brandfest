# Image provider: fal | vertex | openai
IMAGE_PROVIDER=fal

# Model override (optional — defaults shown)
# IMAGE_MODEL=fal-ai/flux-pro/v1.1

# Fal.ai (default provider)
FAL_KEY=your-fal-api-key-here

# Google Vertex AI (optional, only needed if IMAGE_PROVIDER=vertex)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1

# OpenAI (optional, only needed if IMAGE_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key-here

# Vercel Blob (for daily cron auto-generation)
# BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Cron auth secret (optional — protects /api/cron/daily endpoint)
# CRON_SECRET=your-cron-secret
