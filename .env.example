# Image generation provider: fal | vertex | openai
IMAGE_PROVIDER=fal
IMAGE_MODEL=fal-ai/flux-pro/v1.1

# Fal.ai (default provider)
FAL_KEY=your-fal-api-key-here

# Google Vertex AI / Imagen 4 (alternative)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1

# OpenAI GPT Image (alternative)
# OPENAI_API_KEY=your-openai-api-key-here

# Vercel Blob (required for daily auto-mode only)
# BLOB_READ_WRITE_TOKEN=your-blob-token-here

# Vercel Cron security (optional but recommended)
# CRON_SECRET=your-random-secret-here
